# Database Configuration
# SQLite database file path (relative to prisma folder)
# For Windows: use absolute path like file:C:/path/to/project/db/custom.db
DATABASE_URL="file:./db/custom.db"

# =====================================================
# LLM Provider Configuration
# =====================================================
# Default: z-ai (FREE, works automatically, no setup needed!)
# Just run `bun run dev` and it works!
# =====================================================

# For local Ollama (optional, free but requires installation):
# 1. Install Ollama: https://ollama.com
# 2. Run: ollama pull llama3
# 3. Uncomment the lines below:
# LLM_PROVIDER=local
# LLM_ENDPOINT=http://localhost:11434
# LLM_MODEL=llama3

# For external API (optional, requires API key):
# LLM_PROVIDER=api
# LLM_API_KEY=your-api-key
# LLM_API_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_API_MODEL=gpt-4

# Logging level: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO
