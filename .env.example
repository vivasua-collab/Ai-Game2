# Конфигурация базы данных
# Абсолютный путь к файлу БД (будет заменён при инициализации)
# Пример для Windows: file:C:/Users/user/project/db/custom.db
# Пример для Linux/Mac: file:/home/user/project/db/custom.db
DATABASE_URL=file:./db/custom.db

# LLM API ключ (опционально, для внешних провайдеров)
# LLM_API_KEY=your-api-key
# LLM_API_ENDPOINT=https://api.openai.com/v1/chat/completions
